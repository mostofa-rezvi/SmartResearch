# General
NODE_ENV=development
PORT=5000

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=researchbridge
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/researchbridge

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=researchbridge
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Elasticsearch
ELASTICSEARCH_NODE=http://elasticsearch:9200

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_AUTH=neo4j/password

# ML Service
ML_SERVICE_URL=http://ml-service:8000

# Auth
JWT_ACCESS_SECRET=your_access_secret_change_me
JWT_REFRESH_SECRET=your_refresh_secret_change_me
OTP_EXPIRY_MINUTES=5
# Two-factor login: when true, /login emails a 6-digit code and /verify-otp completes login (needs SMTP).
OTP_LOGIN_ENABLED=false

# Hugging Face AI — powers LLM writing feedback / citations + embedding fallback
# Create a token at https://huggingface.co/settings/tokens (a free "read" token works).
# LLM endpoints (/llm/feedback, /llm/citations) return HTTP 503 until HF_API_TOKEN is set.
HF_API_TOKEN=
HF_LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# ML recommender runtime config
# ml-service reads ELASTICSEARCH_URL (backend uses ELASTICSEARCH_NODE above)
ELASTICSEARCH_URL=http://elasticsearch:9200
RECOMMENDATION_THRESHOLD=0.533
